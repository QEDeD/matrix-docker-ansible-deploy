{
    "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
    "python-envs.workspaceSearchPaths": [
        "./.venv"
    ],
    "ansible.ansible.path": "/home/ansible-admin/matrix-docker-ansible-deploy/.venv/bin/ansible",
    "ansible.python.interpreterPath": "/home/ansible-admin/matrix-docker-ansible-deploy/.venv/bin/python",
    "ansible.validation.lint.path": "/home/ansible-admin/matrix-docker-ansible-deploy/.venv/bin/ansible-lint",
    "ansible.lightspeed.enabled": false,
    "ansible.lightspeed.suggestions.enabled": false,
    "python.analysis.exclude": [
        "**/.venv/**",
        "**/var/uv-python/**",
        "**/node_modules/**",
        "**/__pycache__/**",
        "**/.*"
    ],
    "python.analysis.indexing.followSymlinkedFolders": false,
    "files.watcherExclude": {
        "**/.ansible/**": true,
        "**/.mypy_cache/**": true,
        "**/.pytest_cache/**": true,
        "**/.ruff_cache/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/node_modules/**": true,
        "**/var/uv-python/**": true
    },
    "search.exclude": {
        "**/.ansible/**": true,
        "**/.mypy_cache/**": true,
        "**/.pytest_cache/**": true,
        "**/.ruff_cache/**": true,
        "**/.venv/**": true,
        "**/__pycache__/**": true,
        "**/node_modules/**": true,
        "**/var/uv-python/**": true
    }
}
